{
  "name": "tower-defense-tests",
  "version": "1.0.0",
  "description": "Automated test suite for Tower Defense game",
  "main": "test-runner.js",
  "scripts": {
    "test": "node test-runner.js",
    "test:watch": "nodemon --exec node test-runner.js",
    "test:report": "node test-runner.js --report",
    "test:pw": "npx playwright test",
    "test:pw:ui": "npx playwright test --ui",
    "test:pw:debug": "npx playwright test --debug"
  },
  "keywords": [
    "tower-defense",
    "game",
    "tests",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "puppeteer": "^21.11.0",
    "puppeteer-core": "^21.6.0"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.70",
    "@playwright/test": "^1.59.1",
    "nodemon": "^3.0.3",
    "playwright": "^1.59.0"
  }
}
